<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="#1E231F" 
  android:fitsSystemWindows="true">

<LinearLayout
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:orientation="vertical"
  android:padding="20dp"
  android:focusable="true"
  android:focusableInTouchMode="true">

<TextView
  android:layout_width="wrap_content"
  android:layout_height="wrap_content"
  android:text="Campsite Commander"
  android:textColor="#D4A373"
  android:textSize="28sp"
  android:textStyle="bold"
  android:layout_gravity="center"
  android:layout_marginBottom="10dp" />

<TextView
  android:id="@+id/txtTotalItems"
  android:layout_width="wrap_content"
  android:layout_height="wrap_content"
  android:text="Total Items Packed: 0"
  android:textColor="#CCD5AE"
  android:textSize="18sp"
  android:layout_gravity="center"
  android:layout_marginBottom="20dp" />

<EditText
  android:id="@+id/edtItem"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:hint="Gear Item Name"
  android:textColorHint="#8E9B90"
  android:textColor="#FFFFFF"
  android:minHeight="48dp" />

<EditText
  android:id="@+id/edtCategory"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:hint="Category (e.g., Shelter)"
  android:textColorHint="#8E9B90"
  android:textColor="#FFFFFF"
  android:minHeight="48dp" />

<EditText
  android:id="@+id/edtQuantity"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:hint="Quantity"
  android:inputType="number"
  android:textColorHint="#8E9B90"
  android:textColor="#FFFFFF"
  android:minHeight="48dp" />

<EditText
  android:id="@+id/edtComments"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:hint="Notes/Comments"
  android:textColorHint="#8E9B90"
  android:textColor="#FFFFFF"
  android:minHeight="48dp" />

<Button
  android:id="@+id/btnAdd"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:text="Add Gear"
  android:backgroundTint="#4A5D23"
  android:textColor="#FFFFFF"
  android:layout_marginTop="10dp" />

<Button
  android:id="@+id/btnView"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:text="View Checklist"
  android:backgroundTint="#4A5D23"
  android:textColor="#FFFFFF"
  android:layout_marginTop="10dp" />

<Button
  android:id="@+id/btnExit"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:text="Exit"
  android:backgroundTint="#6B2D2D"
  android:textColor="#FFFFFF"
  android:layout_marginTop="10dp" />

    </LinearLayout>

  </ScrollView>
